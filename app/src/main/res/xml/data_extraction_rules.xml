<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup rules. Sensitive financial data stays on device.
    Device-transfer (phone-to-phone setup) keeps the DB so users don't
    lose receipts when switching phones.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="freelance_receipt_db" />
        <exclude domain="database" path="freelance_receipt_db-shm" />
        <exclude domain="database" path="freelance_receipt_db-wal" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="freelance_receipt_db" />
    </device-transfer>
</data-extraction-rules>
